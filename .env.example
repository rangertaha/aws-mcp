# aws-mcp environment configuration.
# Copy to .env and fill in your values:  cp .env.example .env
#
# Credentials are read from the standard AWS credential chain (these env vars,
# ~/.aws/config & ~/.aws/credentials, SSO, or an attached IAM role). aws-mcp
# does not store credentials itself.

# Standard AWS credential variables (one option among many):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# AWS_PROFILE=

# Region (standard AWS variable; also used as the region override).
AWS_REGION=us-east-1

# --- Server behavior ---
# Comma-separated toolset names to enable, or "all" (default).
AWS_TOOLSETS=all

# "true" exposes only read-only tools.
AWS_READONLY=false
